{
  "name": "clawcenter",
  "version": "0.1.0",
  "description": "Central router bridging multiple WeChat accounts to multiple AI agents",
  "type": "module",
  "bin": {
    "clawcenter": "./bin/clawcenter.js"
  },
  "scripts": {
    "build": "tsc && vite build --config web/vite.config.ts",
    "build:server": "tsc",
    "build:web": "vite build --config web/vite.config.ts",
    "dev": "tsx src/index.ts start",
    "dev:worker": "tsx src/index.ts start --worker",
    "start": "node dist/index.js start",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.2",
    "commander": "^13.1.0",
    "fastify": "^5.3.3",
    "ink": "^6.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "sql.js": "^1.12.0",
    "ws": "^8.18.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.8",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.2",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitepress": "^1.6.4"
  }
}
